# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PROGRAM_A_SETUP=price_...
STRIPE_PRICE_ID_PROGRAM_A_MONTHLY=price_...
STRIPE_PRICE_ID_PROGRAM_B_SETUP=price_...
STRIPE_PRICE_ID_PROGRAM_B_MONTHLY=price_...
STRIPE_PRICE_ID_PROGRAM_C_MONTHLY=price_...

# LLM (server-side OpenAI)
OPENAI_API_KEY=sk-...
# Optional: override the model used by portal AI routes
OPENAI_MODEL=gpt-4o-mini
# Deprecated: Anthropic/Claude is no longer used by portal AI routes.
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BOOKING_URL=https://calendar.app.google/PGkzpGXXjRHkLHTEA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Partner Affiliate Links
NEXT_PUBLIC_KASHU_AFFILIATE_URL=https://signup.kashupay.com?referrer=QocxmFiGV17zvJ

# Google Calendar CRM booking
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/admin/crm/google-calendar/callback
GOOGLE_REFRESH_TOKEN=your-google-refresh-token
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=America/New_York

# Campaign Email SES
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_SES_CONFIGURATION_SET=your-campaign-configuration-set
AWS_SES_CAMPAIGN_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:your-campaign-topic
AWS_SES_FROM_EMAIL=no-reply@your-verified-domain.com
AWS_SES_FROM_NAME=SourcifyLending Campaigns
