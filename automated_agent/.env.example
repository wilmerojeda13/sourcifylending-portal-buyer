# Copy this file to .env.local in the PARENT directory (project root)
# The agent reads from ../.env.local

# Required: Supabase connection
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Set to 'true' for dry-run mode (logs only, no DB changes)
# DRY_RUN=false
